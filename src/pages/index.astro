---
import { CONTACT } from '../data/cv';
import CvApp from '../components/CvApp.astro';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%E2%9D%84%EF%B8%8F%3C/text%3E%3C/svg%3E" />
    <title>{CONTACT.name} — Front-End Lead</title>
    <meta
      name="description"
      content="CV de Edgar Contreras — Desarrollador de Software y Front-End Lead. Estética Omarchy, tema Nord."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      try {
        var saved = localStorage.getItem('cv_lang');
        document.documentElement.dataset.lang = saved === 'en' ? 'en' : 'es';
      } catch (e) {
        document.documentElement.dataset.lang = 'es';
      }
    </script>
  </head>
  <body>
    <CvApp />
    <script>
      import '../scripts/app.ts';
    </script>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
  }
  body {
    font-family: 'Fira Code', ui-monospace, 'SFMono-Regular', Menlo, monospace;
    -webkit-font-smoothing: antialiased;
    background: #272c36;
  }
  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }
  ::selection {
    background: #88c0d0;
    color: #2e3440;
  }
  ::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: #434c5e;
    border-radius: 8px;
    border: 2px solid #2e3440;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #4c566a;
  }

  /* --- i18n: se muestra solo el bloque que coincide con html[data-lang] --- */
  html:not([data-lang='en']) [data-i18n='en'] {
    display: none;
  }
  html[data-lang='en'] [data-i18n='es'] {
    display: none;
  }
  html:not([data-lang='en']) [data-lang-flag='en'],
  html[data-lang='en'] [data-lang-flag='es'] {
    color: #4c566a;
    font-weight: 400;
  }
  html:not([data-lang='en']) [data-lang-flag='es'],
  html[data-lang='en'] [data-lang-flag='en'] {
    color: #88c0d0;
    font-weight: 600;
  }

  /* --- Paneles: visibles solo si coinciden idioma (arriba) y pestaña activa --- */
  .cv-panel {
    display: none;
  }
  .cv-panel.is-active {
    display: block;
  }

  /* --- Estados activos de botones (tabs / workspace switcher) --- */
  .tab-btn {
    background: transparent;
    color: #81a1c1;
    border-color: #434c5e;
  }
  .tab-btn.is-active {
    background: #88c0d0;
    color: #2e3440;
    border-color: #88c0d0;
    font-weight: 600;
  }
  .tab-switch-btn.is-active {
    background: #88c0d0;
    color: #2e3440;
    border-color: #88c0d0;
    font-weight: 600;
  }

  /* --- Responsive: móvil (base) / tablet (≥641px) / web (≥1025px) --- */
  html {
    overflow-x: hidden;
  }
  .topbar {
    flex-wrap: wrap;
    row-gap: 6px;
    padding: 8px 12px;
  }
  .topbar-icons,
  .topbar-status {
    display: none;
  }
  .terminal-shell {
    margin: 18px 10px 40px;
    border-radius: 10px;
  }
  .term-body {
    padding: 18px 16px 22px;
  }
  .profile-row {
    gap: 16px;
  }
  .profile-info {
    min-width: 0;
  }
  .ascii-art {
    display: none;
  }
  .profile-name {
    font-size: 19px;
  }
  .tabs-row {
    gap: 6px;
  }
  .tab-btn {
    font-size: 12px !important;
    padding: 5px 10px !important;
  }
  .cmd-line {
    font-size: 12.5px;
  }

  @media (min-width: 641px) {
    .topbar {
      flex-wrap: nowrap;
      padding: 8px 16px;
    }
    .topbar-icons,
    .topbar-status {
      display: inline-flex;
    }
    .terminal-shell {
      margin: 26px 16px 48px;
      border-radius: 12px;
    }
    .term-body {
      padding: 22px 24px 28px;
    }
    .profile-info {
      min-width: 260px;
    }
    .ascii-art {
      display: block;
    }
    .profile-name {
      font-size: 21px;
    }
    .tab-btn {
      font-size: 12.5px !important;
      padding: 6px 12px !important;
    }
  }

  @media (min-width: 1025px) {
    .terminal-shell {
      margin: 34px 18px 56px;
      border-radius: 14px;
    }
    .term-body {
      padding: 26px 30px 32px;
    }
    .profile-info {
      min-width: 300px;
    }
    .profile-name {
      font-size: 23px;
    }
    .tab-btn {
      font-size: 13px !important;
      padding: 6px 14px !important;
    }
    .cmd-line {
      font-size: 13.5px;
    }
  }
</style>
