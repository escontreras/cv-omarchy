---
import { CONTACT } from '../data/cv';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%E2%9D%84%EF%B8%8F%3C/text%3E%3C/svg%3E" />
    <title>{CONTACT.name} — Front-End Lead</title>
    <meta
      name="description"
      content="CV de Edgar Contreras — Desarrollador de Software y Front-End Lead. Estética Omarchy, tema Nord."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="app"></div>
    <script>
      import '../scripts/app.ts';
    </script>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
  }
  body {
    font-family: 'Fira Code', ui-monospace, 'SFMono-Regular', Menlo, monospace;
    -webkit-font-smoothing: antialiased;
    background: #272c36;
  }
  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }
  ::selection {
    background: #88c0d0;
    color: #2e3440;
  }
  ::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: #434c5e;
    border-radius: 8px;
    border: 2px solid #2e3440;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #4c566a;
  }
</style>
