---
import { TABS } from '../data/cv';
import { UI } from '../lib/icons';
---

<div class="topbar sticky top-0 z-20 flex w-full items-center gap-[12px] border-b border-nord-1 bg-nord-0/[.72] text-[12.5px] text-nord-4 backdrop-blur-[10px]">
  <div class="flex items-center gap-[8px] font-semibold text-nord-8">
    <span class="text-[14px]">❄</span><span class="tracking-[.04em]">omarchy</span>
  </div>

  <div class="ml-[4px] flex items-center gap-[6px]">
    {TABS.map((t, i) => (
      <button type="button" data-ws-btn={t.id} class="tab-switch-btn flex h-[22px] w-[22px] items-center justify-center rounded-[6px] border border-nord-1 text-[12px] text-nord-3 transition-[filter] duration-150">{i + 1}</button>
    ))}
  </div>

  <div class="flex-1"></div>
  <span class="text-nord-muted">[<span id="tab-label">{TABS[0].es}</span>]</span>
  <div class="flex-1"></div>

  <button type="button" data-action="lang" class="inline-flex items-center gap-[6px] rounded-full border border-nord-2 bg-nord-1 px-[10px] py-[3px] font-mono text-[12px] text-nord-4">
    <span data-lang-flag="es" class="text-nord-8 font-semibold">ES</span><span class="text-nord-3">/</span><span data-lang-flag="en" class="text-nord-3">EN</span>
  </button>

  <span class="topbar-status items-center gap-[6px] text-nord-14">
    <span class="inline-block h-[7px] w-[7px] rounded-full bg-nord-14"></span>
    <span data-i18n="es">ES · nativo</span><span data-i18n="en">EN · B1</span>
  </span>
  <span class="topbar-icons items-center gap-[11px] text-nord-9">
    <Fragment set:html={UI.wifi} />
    <Fragment set:html={UI.vol} />
    <Fragment set:html={UI.batt} />
  </span>
  <span id="clock" class="min-w-[70px] text-right text-nord-13"></span>
</div>
